<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tacos_Gomez_NEW.GeneradorReportes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:local="using:Tacos_Gomez_NEW">

    <Page.Resources>
        <local:CurrencyConverter x:Key="MonedaConverter"/>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.7*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Analítica de Negocio - Tacos Gómez" FontSize="28" FontWeight="Bold" Grid.ColumnSpan="2" Margin="0,0,0,20" Foreground="{ThemeResource SystemAccentColor}"/>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <ComboBox x:Name="cbReportes" Header="Seleccionar Reporte" Width="250" VerticalAlignment="Bottom" SelectionChanged="cbReportes_SelectionChanged">
                <ComboBoxItem Content="Ventas Detalladas"/>
                <ComboBoxItem Content="Top 10 Productos"/>
                <ComboBoxItem Content="Resumen de Ordenes"/>
                <ComboBoxItem Content="Ingresos por Mes"/>
                <ComboBoxItem Content="Fidelidad de Clientes"/>
                <ComboBoxItem Content="Ranking de Empleados"/>
                <ComboBoxItem Content="Ventas por Categoria"/>
                <ComboBoxItem Content="Reporte de Ordenes por Cliente"/>
                <ComboBoxItem Content="Ticket Promedio"/>
                <ComboBoxItem Content="Eficiencia de Ordenes"/>
            </ComboBox>

            <AutoSuggestBox x:Name="asbCliente" Header="Buscar Cliente" PlaceholderText="Escriba nombre..." Width="250" 
                            VerticalAlignment="Bottom" Visibility="Collapsed"
                            TextChanged="asbCliente_TextChanged" SuggestionChosen="asbCliente_SuggestionChosen"/>

            <CalendarDatePicker x:Name="dtpInicio" Header="Desde" Width="130" VerticalAlignment="Bottom"/>
            <CalendarDatePicker x:Name="dtpFin" Header="Hasta" Width="130" VerticalAlignment="Bottom"/>
            <Button Content="Analizar" Click="btnGenerar_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
            <AppBarSeparator VerticalAlignment="Bottom"/>
            <Button Content="Excel" Click="btnExcel_Click" Background="#1D6F42" Foreground="White" VerticalAlignment="Bottom"/>
            <Button Content="PDF" Click="btnPDF_Click" Background="#B30B00" Foreground="White" VerticalAlignment="Bottom"/>
        </StackPanel>

        <controls:DataGrid x:Name="dgVentas" Grid.Row="2" Grid.Column="0" AutoGenerateColumns="False" 
                           IsReadOnly="True" AlternatingRowBackground="#2D2D2D" 
                           GridLinesVisibility="Horizontal" Margin="0,0,15,0"/>

        <Border Grid.Row="2" Grid.Column="1" Background="#1E1E1E" CornerRadius="12" Padding="15" VerticalAlignment="Stretch" BorderBrush="#333333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="lblGrafica" Text="Visualización de Datos" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Gray"/>

                <lvc:PieChart x:Name="graficaPastel" Grid.Row="1" MinHeight="450" Visibility="Collapsed" LegendPosition="Right"/>
                <lvc:CartesianChart x:Name="graficaBarras" Grid.Row="1" MinHeight="500" Visibility="Collapsed" LegendPosition="Hidden"/>
            </Grid>
        </Border>
    </Grid>
</Page>