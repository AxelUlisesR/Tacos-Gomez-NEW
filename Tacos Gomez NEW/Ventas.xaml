<Page
    x:Class="Tacos_Gomez_NEW.VentasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tacos_Gomez_NEW"
    Loaded="Page_Loaded">

    <Grid Padding="30" RowDefinitions="Auto, *" ColumnDefinitions="400, *">
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="20" Margin="0,0,0,30">
            <SymbolIcon Symbol="Shop" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
            <TextBlock x:Name="txtTitulo" Text="Nueva Orden de Venta" FontSize="28" FontWeight="Bold"/>
            <TextBlock x:Name="txtId" Text="ID: 0" FontSize="28" Opacity="0.5"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" Padding="0,0,20,0">
            <StackPanel Spacing="20">
                <!-- Sección Cliente -->
                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="15" CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Datos del Cliente" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                        <AutoSuggestBox x:Name="asbCliente" Header="Nombre" PlaceholderText="Buscar cliente..." UpdateTextOnSelect="True"
                                        TextChanged="asbCliente_TextChanged" SuggestionChosen="asbCliente_SuggestionChosen" HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="txtDireccion" Header="Calle / Colonia" IsReadOnly="True" Opacity="0.7"/>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtNumCasa" Header="Núm. Casa" IsReadOnly="True" Opacity="0.7"/>
                            <TextBox x:Name="txtTelefono" Grid.Column="1" Header="Teléfono" IsReadOnly="True" Opacity="0.7"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Sección Empleado -->
                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="15" CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Atendido por" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                        <ComboBox x:Name="cbEmpleado" Header="Empleado" HorizontalAlignment="Stretch" SelectionChanged="cbEmpleado_SelectionChanged"/>
                        <TextBox x:Name="txtRol" Header="Puesto" IsReadOnly="True" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- Sección Productos -->
                <Border Background="{ThemeResource SystemControlBackgroundAltMediumHighBrush}" Padding="15" CornerRadius="8">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Añadir al Pedido" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                        <ComboBox x:Name="cboProducto" Header="Producto" HorizontalAlignment="Stretch" SelectionChanged="cboProducto_SelectionChanged"/>
                        <Grid ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <NumberBox x:Name="nbPrecio" Header="Precio" Value="0" IsEnabled="False" SpinButtonPlacementMode="Hidden"/>
                            <NumberBox x:Name="nbCantidad" Header="Cantidad" Grid.Column="1" Value="1" Minimum="1" SpinButtonPlacementMode="Inline"/>
                        </Grid>
                        <Button x:Name="cmdAceptar" Content="Agregar al Plato" Click="cmdAceptar_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Lado derecho: Lista de productos y totales -->
        <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="*, Auto, Auto" Margin="10,0,0,0">
            <Border Grid.Row="0" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="10">
                <ListView x:Name="dgvMenu">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, 100, 80, 100, 60" Padding="12,10,12,10" Background="Black">
                                <TextBlock Grid.Column="0" Text="Producto" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Grid.Column="1" Text="Precio" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="Cant" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Subtotal" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="Plato" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:DetalleVenta">
                            <Grid ColumnDefinitions="*, 100, 80, 100, 60" Height="45">
                                <TextBlock Grid.Column="0" Text="{x:Bind Nombre}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind PrecioFormateado}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Cantidad}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind ImporteFormateado}" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind NoPlato}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">
                <Button x:Name="btnNuevo" Content="Nuevo Pedido" Click="btnNuevo_Click" HorizontalAlignment="Stretch" Height="50"/>
                <Button x:Name="btnGrabar" Grid.Column="1" Content="Imprimir y Cobrar" Click="btnGrabar_Click" HorizontalAlignment="Stretch" Height="50" Background="DarkGreen" Foreground="White"/>
            </Grid>

            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,20,0,0" Width="300" Spacing="5">
                <Grid ColumnDefinitions="*, *">
                    <TextBlock Text="Subtotal:"/>
                    <TextBlock x:Name="txtSubtotal" Grid.Column="1" Text="$0.00" HorizontalAlignment="Right"/>
                </Grid>
                <Grid ColumnDefinitions="*, *">
                    <TextBlock Text="IVA (16%):"/>
                    <TextBlock x:Name="txtIVA" Grid.Column="1" Text="$0.00" HorizontalAlignment="Right"/>
                </Grid>
                <TextBlock x:Name="txtTotal" Text="TOTAL: $0.00" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                <TextBlock x:Name="lblPlato" Text="Plato Actual: 1" FontSize="14" Opacity="0.6" HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>