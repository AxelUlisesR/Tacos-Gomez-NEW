<Page
    x:Class="Tacos_Gomez_NEW.EmpleadosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid Padding="30" RowDefinitions="Auto, *" ColumnDefinitions="400, *">
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="15" Margin="0,0,0,30">
            <SymbolIcon Symbol="Contact" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
            <TextBlock Text="Gestión de Empleados y Usuarios" FontSize="28" FontWeight="Bold"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" Padding="0,0,20,0">
            <StackPanel Spacing="15">
                <TextBox x:Name="txtId" Header="ID Empleado" IsReadOnly="True" Opacity="0.7"/>
                <TextBox x:Name="txtNombre" Header="Nombre Completo" MaxLength="70" PlaceholderText="Ej. Axel Rodríguez"/>

                <Grid ColumnDefinitions="*, 80" ColumnSpacing="10">
                    <AutoSuggestBox x:Name="asbDireccion" Grid.Column="0"
                                    Header="Calle (Sayula, Jal)" 
                                    PlaceholderText="Buscar calle..."
                                    UpdateTextOnSelect="True"
                                    TextChanged="asbDireccion_TextChanged"
                                    SuggestionChosen="asbDireccion_SuggestionChosen"
                                    QueryIcon="Find"/>

                    <TextBox x:Name="txtNumero" Grid.Column="1" 
                             Header="Núm." MaxLength="10" 
                             PlaceholderText="Ext."/>
                </Grid>

                <TextBox x:Name="txtTelefono" Header="Teléfono" MaxLength="13" PlaceholderText="10-13 dígitos"/>

                <ComboBox x:Name="cbRol" Header="Puesto / Rol" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Administrador"/>
                    <ComboBoxItem Content="Cajero"/>
                    <ComboBoxItem Content="Mesero"/>
                    <ComboBoxItem Content="Cocinero"/>
                    <ComboBoxItem Content="Repartidor"/>
                </ComboBox>

                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="15" CornerRadius="8">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Acceso al Sistema" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                        <TextBox x:Name="txtUsername" Header="Usuario (Login)" MaxLength="50"/>
                        <PasswordBox x:Name="txtPassword" Header="Contraseña" PlaceholderText="******"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
                    <Button x:Name="btnNuevo" Content="Nuevo" Click="btnNuevo_Click" Style="{StaticResource AccentButtonStyle}" Width="90"/>
                    <Button x:Name="btnGrabar" Content="Grabar" Click="btnGrabar_Click" Width="90"/>
                    <Button x:Name="btnModificar" Content="Editar" Click="btnModificar_Click" Width="90"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="btnBusca" Content="Buscar ID" Click="btnBusca_Click" Width="140"/>
                    <Button x:Name="btnCancelar" Content="Cancelar" Click="btnCancelar_Click" Width="140"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="10">
            <ListView x:Name="lvEmpleados" SelectionChanged="lvEmpleados_SelectionChanged">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="50, 180, *, 110, 110" Padding="12,0,0,10">
                            <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Nombre" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Dirección" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Teléfono" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="Rol" FontWeight="Bold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="50, 180, *, 110, 110" Height="45">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Nombre}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="{Binding Direccion}" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                <TextBlock Text=" #" Margin="2,0,0,0"/>
                                <TextBlock Text="{Binding Numero}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="{Binding Telefono}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding Rol}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>