<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Tacos_Gomez_NEW.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tacos_Gomez_NEW"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Tacos Gomez NEW">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Frame x:Name="RootFrame">
        <Grid RowDefinitions="Auto, *, Auto" Padding="40">
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
            <TextBlock Text="🌮 Tacos Gomez" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
            <TextBlock Text="PUNTO DE VENTA" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       CharacterSpacing="150"
                       HorizontalAlignment="Center" 
                       Opacity="0.6"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="20" VerticalAlignment="Center" MaxWidth="320">
            <TextBox
                x:Name="txtUsuario"
                Header="Usuario" 
                     PlaceholderText="Ingresa tu nombre" 
                     HorizontalAlignment="Stretch"/>

            <PasswordBox 
                x:Name="txtPassword"
                Header="Contraseña" 
                         PlaceholderText="******" 
                         HorizontalAlignment="Stretch"/>

            <CheckBox Content="Recordar mis datos" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="12" MaxWidth="320">
            <Button x:Name="btnLogin" 
        Content="Iniciar Sesión" 
        Click="btnLogin_Click" 
        HorizontalAlignment="Stretch" 
        Height="40"
        Style="{StaticResource AccentButtonStyle}" />

            <HyperlinkButton Content="¿Problemas para entrar?" 
                             HorizontalAlignment="Center" 
                             FontSize="12"/>
        </StackPanel>
    </Grid>
    </Frame>
</Window>
