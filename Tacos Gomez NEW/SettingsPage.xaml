<Page
    x:Class="Tacos_Gomez_NEW.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tacos_Gomez_NEW">

    <StackPanel Padding="40" Spacing="20">
        <TextBlock Text="Configuración del Sistema" FontSize="28" FontWeight="Bold"/>

        <Border Background="#1E1E1E" Padding="20" CornerRadius="8">
            <StackPanel Spacing="15">
                <TextBlock Text="Mantenimiento de Base de Datos" FontSize="20" FontWeight="SemiBold"/>

                <StackPanel Spacing="10">
                    <TextBlock Text="Copia de Seguridad" FontWeight="Bold" Opacity="0.8"/>
                    <TextBlock Text="Genera un archivo .backup con toda la información actual." FontSize="12" Opacity="0.6"/>
                    <Button x:Name="btnBackup" Content="Crear Respaldo Ahora" Click="btnBackup_Click" Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>

                <MenuFlyoutSeparator/>

                <StackPanel Spacing="10">
                    <TextBlock Text="Restaurar Base de Datos" FontWeight="Bold" Opacity="0.8"/>
                    <TextBlock Text="Selecciona un archivo para sobrescribir la base de datos actual." FontSize="12" Opacity="0.6" Foreground="Orange"/>
                    <Button x:Name="btnRestore" Content="Restaurar desde Archivo" Click="btnRestore_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="Versión 1.0.0 - Sayula, Jalisco" FontSize="12" Opacity="0.4" HorizontalAlignment="Center"/>
    </StackPanel>
</Page>