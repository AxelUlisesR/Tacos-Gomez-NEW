<Page
    x:Class="Tacos_Gomez_NEW.ConsultaVentas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tacos_Gomez_NEW">

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *" Margin="0,0,15,0">
            <TextBlock Grid.Row="0" Text="Historial de Ventas" FontSize="26" FontWeight="Bold" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
                <AutoSuggestBox x:Name="asbBusqueda" PlaceholderText="Folio o nombre del cliente..." Width="350" QueryIcon="Find"
                                TextChanged="asbBusqueda_TextChanged" QuerySubmitted="asbBusqueda_QuerySubmitted" SuggestionChosen="asbBusqueda_SuggestionChosen"/>
                <Button Content="Refrescar" Click="btnRefrescar_Click"/>
            </StackPanel>

            <ListView x:Name="lvVentas" Grid.Row="2" SelectionChanged="lvVentas_SelectionChanged"
                      Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:VentaItem">
                        <Grid Padding="12" ColumnDefinitions="60, *, 100">
                            <TextBlock Grid.Column="0" Text="{x:Bind Id}" FontWeight="Bold" VerticalAlignment="Center" Foreground="SteelBlue" FontSize="16"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Cliente}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="{x:Bind Estado}" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind TotalStr}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="DarkSeaGreen" FontSize="16"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <ScrollViewer>
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Orden #" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="txtDetalleFolio" Text="---" FontSize="22" FontWeight="Bold" Foreground="DodgerBlue"/>
                    </StackPanel>

                    <StackPanel Spacing="5" Padding="10" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Contact" Foreground="Gray"/>
                            <TextBlock Text="Cliente:" FontWeight="SemiBold" Width="70"/>
                            <TextBlock x:Name="txtDetalleCliente" Text="---" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="People" Foreground="Gray"/>
                            <TextBlock Text="Vendedor:" FontWeight="SemiBold" Width="70"/>
                            <TextBlock x:Name="txtDetalleVendedor" Text="---" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Productos" FontWeight="Bold" Margin="0,10,0,0"/>
                    <ListView x:Name="lvDetalle" Height="220" SelectionMode="None">
                        <ListView.Header>
                            <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,15,10">
                                <TextBlock Grid.Column="0" Text="Producto" FontSize="12" FontWeight="Bold" Foreground="DimGray"/>
                                <TextBlock Grid.Column="1" Text="Cant." FontSize="12" FontWeight="Bold" Foreground="DimGray" Margin="15,0"/>
                                <TextBlock Grid.Column="2" Text="Subtotal" FontSize="12" FontWeight="Bold" Foreground="DimGray"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:DetalleItem">
                                <Grid ColumnDefinitions="*, Auto, Auto" Padding="0,5">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Producto}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Cantidad}" Margin="15,0" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind SubtotalStr}" Foreground="ForestGreen" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="TOTAL DE ORDEN:" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="txtDetalleTotal" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="ForestGreen" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <MenuFlyoutSeparator/>
                    <TextBlock Text="Estado de la Venta:" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbEstados" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Activa"/>
                        <ComboBoxItem Content="Pagada"/>
                        <ComboBoxItem Content="Cancelada"/>
                    </ComboBox>

                    <TextBlock x:Name="txtEstadoAviso" Text="⚠ Orden finalizada, no se permiten cambios." Foreground="Firebrick" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed"/>
                    <Button x:Name="btnActualizarEstado" Content="Guardar Cambios" Click="btnActualizarEstado_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Height="40"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>