<Page
    x:Class="Tacos_Gomez_NEW.ProductosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid Padding="30" RowDefinitions="Auto, *" ColumnDefinitions="350, *">
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="15" Margin="0,0,0,30">
            <SymbolIcon Symbol="Shop" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
            <TextBlock Text="Catálogo de Productos" FontSize="28" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="15" Margin="0,0,30,0">
            <TextBox x:Name="txtId" Header="ID Producto" IsReadOnly="True" Opacity="0.7"/>
            <TextBox x:Name="txtNombre" Header="Nombre del Producto" PlaceholderText="Ej. Taco de Pastor" MaxLength="60"/>

            <NumberBox x:Name="nbPrecio" Header="Precio ($)" 
                       PlaceholderText="0.00"  
                       SmallChange="1" 
                       Value="0"
                       SpinButtonPlacementMode="Inline"/>

            <ComboBox x:Name="cbCategoria" Header="Categoría" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Taco"/>
                <ComboBoxItem Content="Quesadilla"/>
                <ComboBoxItem Content="Torta"/>
                <ComboBoxItem Content="Bebida"/>
                <ComboBoxItem Content="Postre"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
                <Button x:Name="btnNuevo" Content="Nuevo" Click="btnNuevo_Click" Style="{StaticResource AccentButtonStyle}" Width="80"/>
                <Button x:Name="btnGrabar" Content="Grabar" Click="btnGrabar_Click" Width="80"/>
                <Button x:Name="btnModificar" Content="Editar" Click="btnModificar_Click" Width="80"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="btnBusca" Content="Buscar ID" Click="btnBusca_Click" Width="125"/>
                <Button x:Name="btnCancelar" Content="Cancelar" Click="btnCancelar_Click" Width="125"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="10">
            <ListView x:Name="lvProductos" SelectionChanged="lvProductos_SelectionChanged">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="60, 250, 120, *" Padding="12,10,12,10" Background="Black" CornerRadius="8,8,0,0">
                            <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="Nombre" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="2" Text="Precio" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="3" Text="Categoría" FontWeight="Bold" Foreground="White"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="60, 250, 120, *" Height="45">
                            <TextBlock Grid.Column="0" Text="{Binding Id}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Nombre}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding PrecioFormateado}" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="{Binding Categoria}" VerticalAlignment="Center" Opacity="0.8"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>